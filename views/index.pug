extends layout

block title
  = title

block content

  // Header superior
  header.main-header
    .container.text-center

      h1.titulo-sistema Bienvenido al Sistema de Gestión de Consultas Médicas

      if usuario
        .mt-3.mb-4.text-center
          h5.mb-1
            i.bi.bi-person-circle.me-2
            | #{usuario.nombre}

          p.text-muted.mb-0
            i.bi.bi-shield-lock.me-2
            | #{usuario.rol}

  // Contenido existente
  .text-center.mt-5
    h1= message

    .container.mt-5
      .row.justify-content-center.g-4

        // ==========================
        // DASHBOARD POR ROL
        // ==========================

        // ADMIN
        if usuario && usuario.rol === 'admin'

          .col-md-4
            a.card.dashboard-card.text-center(href='/turnos')
              h5 Gestionar Turnos
              img.icono.mt-3(src='/img/turnos.png')

          .col-md-4
            a.card.dashboard-card.text-center(href='/profesionales')
              h5 Gestionar Profesionales
              img.icono.mt-3(src='/img/profesionales.png')

          .col-md-4
            a.card.dashboard-card.text-center(href='/pacientes')
              h5 Gestionar Pacientes
              img.icono.mt-3(src='/img/pacientes.png')

          .col-md-4
            a.card.dashboard-card.text-center(href='/agendas')
              h5 Gestionar Agendas
              img.icono.mt-3(src='/img/agendas.png')

          .col-md-4
            - const alertaAusencias = cantidadSolicitudesAusencias > 0

            a.card.dashboard-card.text-center(href='/ausencias')

              if alertaAusencias
                span.dashboard-badge= cantidadSolicitudesAusencias

              h5 Gestionar Ausencias
              img.icono.mt-3(src='/img/ausencias.png')

        // SECRETARIA
        if usuario && usuario.rol === 'secretaria'

          .col-md-4
            a.card.dashboard-card.text-center(href='/turnos')
              h5 Gestionar Turnos
              img.icono.mt-3(src='/img/turnos.png')

          .col-md-4
            a.card.dashboard-card.text-center(href='/pacientes')
              h5 Gestionar Pacientes
              img.icono.mt-3(src='/img/pacientes.png')

          .col-md-4
            a.card.dashboard-card.text-center(href='/agendas')
              h5 Gestionar Agendas
              img.icono.mt-3(src='/img/agendas.png')

          .col-md-4
            a.card.dashboard-card.text-center(href='/ausencias')
              h5 Gestionar Ausencias
              img.icono.mt-3(src='/img/ausencias.png')

        // MEDICO
        if usuario && usuario.rol === 'medico'

          .col-md-4
            a.card.dashboard-card.text-center(href='/mis-turnos')
              h5 Mis Turnos
              img.icono.mt-3(src='/img/turnos.png')

          .col-md-4
            a.card.dashboard-card.text-center(href='/agendas')
              h5 Mi Agenda
              img.icono.mt-3(src='/img/agendas.png')

          .col-md-4
            a.card.dashboard-card.text-center(href='/ausencias')
              h5 Mis Ausencias
              img.icono.mt-3(src='/img/ausencias.png')

        // REPROGRAMACIONES
        if usuario && (usuario.rol === 'admin' || usuario.rol === 'secretaria')

          .col-md-4
            - const alerta = cantidadReprogramaciones > 0

            a.card.dashboard-card.text-center(href='/turnos/reprogramaciones')

              if alerta
                span.dashboard-badge= cantidadReprogramaciones

              h5 Reprogramaciones
              img.icono.mt-3(src='/img/turnos.png')