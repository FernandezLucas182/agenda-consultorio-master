extends layout

block title
  | Agenda de Consultorios

block content

  h1.mb-4 Agenda de Atención

  // 🔍 BUSCADOR
  div.d-flex.gap-2.mb-3

    form(
      method="GET"
      action="/agendas"
      style="flex:1; display:flex; gap:8px;"
    )

      input.form-control(
        type="text"
        name="buscar"
        placeholder="Buscar por profesional, especialidad o sucursal"
        value=buscar
      )

      button.btn.btn-primary(type="submit") Buscar

    a.btn.btn-secondary(href="/agendas") Mostrar todos

  div.d-flex.gap-2.mb-4
    a.btn.btn-primary(href="/agendas/nueva") + Crear Agenda
    a.btn.btn-secondary(href="/") Volver al inicio

  - const dias = ['Lunes','Martes','Miércoles','Jueves','Viernes','Sábado','Domingo']

  if agendas.length > 0

    each ag in agendas

      div.mt-3.px-2.py-1.rounded(
        class=(ag.id == nuevaAgendaId ? 'turno-recien-creado-agenda' : '')
        style="background:#e8f1ff; border-left:3px solid #0d6efd; margin-bottom:1px; display:flex; justify-content:space-between; align-items:center;"
      )

        span.fw-semibold= ag.profesional

        a.btn.btn-warning.btn-sm(
          href=`/agendas/${ag.id}/editar`
        ) Editar agenda

      table.table.table-striped.table-bordered.table-sm.mt-0

        thead.table-dark
          tr
            th Especialidad
            th Día
            th Desde
            th Hasta
            th Duración
            th Máx. Sobreturnos
            th Sucursal
            th Acciones

        tbody

          each item in ag.filas
            tr
              td= item.especialidad
              td= dias[item.dia_semana - 1]
              td= item.hora_inicio
              td= item.hora_fin
              td= item.duracion_turno
              td= item.max_sobreturnos
              td= item.sucursal || 'Sin sucursal'

              td
                a.btn.btn-info.btn-sm.me-1(
                  href=`/agendas/${item.agenda_id}`
                ) Ver

  else

    p.alert.alert-info No hay agendas cargadas.