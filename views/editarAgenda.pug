extends layout

block title
  | Editar Agenda

block content
  h1 Editar Agenda: #{agenda.nombre_completo}
  p.text-muted Especialidad: #{agenda.especialidad} | Sucursal: #{agenda.sucursal_nombre || 'N/A'}

  if error
    div.alert.alert-danger= error

  form(action=`/agendas/${agenda.id}/editar` method="POST")
    
    // CONFIGURACIÓN GENERAL
    div.row.g-3.mb-4.p-3.bg-light.border.rounded
      div.col-md-6
        label.form-label(for="duracion_turno") Duración del Turno (minutos)
        input.form-control(type="number" name="duracion_turno" value=agenda.duracion_turno required)
      div.col-md-6
        label.form-label(for="max_sobreturnos") Máx. Sobreturnos
        input.form-control(type="number" name="max_sobreturnos" value=agenda.max_sobreturnos required)

    // DISPONIBILIDAD
    h3.mb-3 Disponibilidad Semanal

    // Iteramos sobre los días de la semana
    each dia in dias
      div.card.mb-3
        div.card-header
          strong= dia.nombre
        
        div.card-body(id=`bloques-${dia.id}`)
          //- Si existen horarios para este día, los renderizamos
          if horarios[dia.id] && horarios[dia.id].length > 0
            each h, index in horarios[dia.id]
              div.row.g-2.align-items-center.mb-2.bloque-existente
                input(type="hidden" name=`horarios[${dia.id}_${index}][dia]` value=dia.id)
                
                div.col-auto
                  label.col-form-label Desde:
                div.col-auto
                  select.form-select.form-select-sm(name=`horarios[${dia.id}_${index}][desde]` required)
                    each hora in horariosDisponibles
                      option(value=hora selected=(hora == h.hora_inicio.slice(0,5)))= hora
                
                div.col-auto
                  label.col-form-label Hasta:
                div.col-auto
                  select.form-select.form-select-sm(name=`horarios[${dia.id}_${index}][hasta]` required)
                    each hora in horariosDisponibles
                      option(value=hora selected=(hora == h.hora_fin.slice(0,5)))= hora
                
                div.col-auto
                  button.btn.btn-danger.btn-sm(type="button" onclick="this.parentElement.parentElement.remove()") X

        div.card-footer
          button.btn.btn-outline-primary.btn-sm(type="button" onclick=`agregarBloque(${dia.id})`) + Agregar bloque horario

    div.mt-4
      button.btn.btn-success.btn-lg(type="submit") Guardar Cambios
      a.btn.btn-secondary.btn-lg.ms-2(href="/agendas") Cancelar

  // SCRIPT PARA AGREGAR BLOQUES DINÁMICAMENTE
  script.
    // Traemos los horarios disponibles desde el servidor (pug variable) a JS
    const horariosDisponibles = !{JSON.stringify(horariosDisponibles)};
    
    // Generamos un índice único grande para evitar colisiones con los existentes
    let bloqueIndex = 1000;

    function agregarBloque(dia) {
      const contenedor = document.getElementById('bloques-' + dia);

      const div = document.createElement('div');
      div.className = 'row g-2 align-items-center mb-2';

      // Construir opciones del select
      const options = horariosDisponibles
        .map(h => `<option value="${h}">${h}</option>`)
        .join('');

      div.innerHTML = `
        <input type="hidden" name="horarios[new_${bloqueIndex}][dia]" value="${dia}">
        
        <div class="col-auto">
          <label class="col-form-label">Desde:</label>
        </div>
        <div class="col-auto">
          <select class="form-select form-select-sm" name="horarios[new_${bloqueIndex}][desde]" required>
            <option value="">--</option>
            ${options}
          </select>
        </div>

        <div class="col-auto">
          <label class="col-form-label">Hasta:</label>
        </div>
        <div class="col-auto">
          <select class="form-select form-select-sm" name="horarios[new_${bloqueIndex}][hasta]" required>
            <option value="">--</option>
            ${options}
          </select>
        </div>

        <div class="col-auto">
          <button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.parentElement.remove()">X</button>
        </div>
      `;

      contenedor.appendChild(div);
      bloqueIndex++;
    }