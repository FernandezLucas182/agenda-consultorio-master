doctype html
html
  head
    title Crear Nuevo Turno
    link(rel='stylesheet', href='/styles.css')
  body
    h1 Crear Nuevo Turno

    if error
      div(style="color:red; margin-bottom:15px; font-weight:bold;")
        | #{error}

    form(action='/turnos', method='POST')

      div 
        label Tipo de turno
        select(name="tipo_turno" id="tipo_turno")
          option(value="normal") Normal
          option(value="sobreturno") Sobreturno

      div
        label Paciente:
        select(name='paciente_id' required)
          option(value='') Selecciona un paciente
          each p in pacientes
            option(value=p.id)= p.nombre

      div
        label Especialidad:
        select(name='especialidad_id' id='especialidad_id' required)
          option(value='') Selecciona una especialidad
          each especialidad in especialidades
            option(value=especialidad.id)= especialidad.nombre

      div
        label Profesional:
        select(name='profesional_id' id='profesional_id' required)
          option(value='') Selecciona un profesional

      div
        label Sucursal:
        select(name='sucursal_id' required)
          option(value='') Selecciona una sucursal
          each sucursal in sucursales
            option(value=sucursal.id)= sucursal.nombre

      div
        label Fecha:
        input(type='date', name='fecha', id='fecha', required)

      div
        label Hora:
        select(name='hora', id='hora', required)
          option(value='') Selecciona un horario

      // 🔵 SECCIÓN VISUAL NUEVA (NO ROMPE NADA)
      div
        label Selección visual:
        div#slots(style="display:flex; flex-wrap:wrap; gap:8px; margin-top:10px;")

      div
        button(type='submit') Crear Turno

    a(href='/turnos') Volver a la lista de turnos


    // ======================
    // JS
    // ======================
    script.
      document.addEventListener('DOMContentLoaded', () => {

        const especialidad = document.getElementById('especialidad_id');
        const profesional = document.getElementById('profesional_id');
        const fecha = document.getElementById('fecha');
        const hora = document.getElementById('hora');
        const slots = document.getElementById('slots');
        const tipoTurnoSelect = document.getElementById('tipo_turno');

        // Cargar profesionales por especialidad
        especialidad.addEventListener('change', () => {
          fetch(`/profesionales/especialidad/${especialidad.value}`)
            .then(r => r.json())
            .then(data => {
              profesional.innerHTML = '<option value="">Selecciona un profesional</option>';
              data.forEach(p => {
                profesional.innerHTML += `<option value="${p.id}">${p.nombre_completo}</option>`;
              });
            });
        });

        function cargarHorarios() {

          if (!profesional.value || !fecha.value) return;

          fetch(`/turnos/horarios-disponibles/${profesional.value}/${fecha.value}`, {
            cache: "no-store"
          })
            .then(r => r.json())
            .then(data => {

              slots.innerHTML = '';
              hora.innerHTML = '<option value="">Selecciona un horario</option>';

              if (data.motivo === 'ausente') {
                slots.innerHTML = "<p style='color:red; font-weight:bold;'>El profesional no atiende en esta fecha (ausencia registrada).</p>";
                hora.innerHTML = '<option value="">No disponible</option>';
                return;
              }

              if (data.motivo === 'sin_agenda') {
                slots.innerHTML = "<p style='color:orange;'>El profesional no tiene agenda cargada para ese día.</p>";
                hora.innerHTML = '<option value="">No disponible</option>';
                return;
              }

              if (data.motivo) {
                slots.innerHTML = "<p style='color:red;'>Error al obtener horarios.</p>";
                return;
              }

              const libres = data.libres || [];
              const ocupados = data.ocupados || [];
              const tipoTurno = tipoTurnoSelect.value;

              const todos = [...new Set([...libres, ...ocupados])].sort();
              
              console.log("LIBRES:", libres);
              console.log("OCUPADOS:", ocupados);


              todos.forEach(h => {

                const esOcupado = ocupados.includes(h);
                const esSobreturno = tipoTurno === 'sobreturno';

                const option = document.createElement('option');
                option.value = h;

                if (esOcupado && !esSobreturno) {
                  option.textContent = h + " (Ocupado)";
                  option.disabled = true;
                } else if (esOcupado && esSobreturno) {
                  option.textContent = h + " (Sobreturno)";
                } else {
                  option.textContent = h;
                }

                hora.appendChild(option);

                const btn = document.createElement('button');
                btn.type = "button";
                btn.textContent = h;
                btn.style.padding = "6px 10px";
                btn.style.border = "1px solid #ccc";
                btn.style.color = "white";

                if (esOcupado && !esSobreturno) {
                  btn.style.backgroundColor = "#f44336"; // 🔴 rojo
                  btn.disabled = true;
                } else if (esOcupado && esSobreturno) {
                  btn.style.backgroundColor = "#03a9f4"; // 🔵 celeste
                } else {
                  btn.style.backgroundColor = "#4CAF50"; // 🟢 verde
                }

                btn.onclick = () => {
                  hora.value = h;
                  document.querySelectorAll('#slots button')
                    .forEach(b => b.style.outline = "none");
                  btn.style.outline = "3px solid black";
                };

                slots.appendChild(btn);

              });

            })
            .catch(err => console.error("Error cargando horarios:", err));
        }

        profesional.addEventListener('change', cargarHorarios);
        fecha.addEventListener('change', cargarHorarios);
        tipoTurnoSelect.addEventListener('change', cargarHorarios);

      });