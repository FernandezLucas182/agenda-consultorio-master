extends layout

block title
  | Nuevo Turno

block content
  h1 Nuevo Turno

  //- Bloque para mostrar errores si el controlador los envía
  if error && error.length > 0
    div.alert.alert-danger= error[0]

  form(action="/turnos" method="POST")
    div.row.g-3
      //- Paciente
      div.col-md-6
        label.form-label(for="paciente_id") Paciente

        select.form-select(
          name="paciente_id"
          id="paciente_id"
          required
          disabled=(pacienteSeleccionado ? true : false)
        )
          if !pacienteSeleccionado
            option(value="" disabled selected) -- Seleccione Paciente --

          each paciente in pacientes
            option(
              value=paciente.id
              selected=(pacienteSeleccionado && paciente.id == pacienteSeleccionado.id)
            )= paciente.nombre

        //- 🔴 Esto asegura que se envíe el dato aunque esté disabled
        if pacienteSeleccionado
          input(type="hidden" name="paciente_id" value=pacienteSeleccionado.id)

      //- Especialidad
      div.col-md-6
        label.form-label(for="especialidad_id") Especialidad
        select.form-select(name="especialidad_id" id="especialidad_id" required)
          option(value="" disabled selected) -- Seleccione Especialidad --
          each especialidad in especialidades
             option(value=especialidad.id)= especialidad.nombre

      //- Profesional (Se carga dinámicamente)
      div.col-md-6
        label.form-label(for="profesional_id") Profesional
        select.form-select(name="profesional_id" id="profesional_id" required disabled)
          option(value="" disabled selected) -- Primero seleccione especialidad --

      
      //- Fecha
      div.col-md-6
        label.form-label(for="fecha") Fecha
        input.form-control(
          type="text"
          name="fecha"
          id="fecha"
          placeholder="Seleccione fecha"
          autocomplete="off"
          required
        )

      //- Hora (Se carga dinámicamente)
      div.col-md-6
        label.form-label(for="hora") Horarios Disponibles
          small.text-muted.d-block.mb-1
           | 🟢 Libre | 🔵 Sobreturno | 🔴 Completo
        select.form-select(name="hora" id="hora" required disabled)
          option(value="" disabled selected) -- Seleccione fecha y profesional --
        div#mensajeTurno.mt-2

      //- Tipo de Turno
      div.col-md-6
        label.form-label(for="tipo_turno") Tipo de Turno
        select.form-select(name="tipo_turno" id="tipo_turno")
          option(value="normal") Normal
          option(value="sobreturno") Sobreturno

    div.mt-4
      button.btn.btn-primary(type="submit") Crear Turno
      a.btn.btn-secondary.ms-2(href="/turnos") Cancelar

  //- Scripts para la lógica dinámica
  script.
    const especialidadSelect = document.getElementById('especialidad_id');
    const profesionalSelect = document.getElementById('profesional_id');
    const fechaInput = document.getElementById('fecha');
    const horaSelect = document.getElementById('hora');
    const pacienteSelect = document.getElementById('paciente_id');
    const mensajeDiv = document.getElementById('mensajeTurno');
    const tipoTurnoSelect = document.getElementById('tipo_turno');

    // 1. Pre-seleccionar paciente si viene en la URL (desde detallePaciente)
    const urlParams = new URLSearchParams(window.location.search);
    const pacienteIdParam = urlParams.get('paciente_id');

    const estado = {
      especialidad: null,
      profesional: null,
      fecha: null,
      tipo: 'normal'
    };

    let cargandoHorarios = false;

    if (pacienteIdParam && pacienteSelect && !pacienteSelect.disabled) {
      pacienteSelect.value = pacienteIdParam;
    }

    // 2. Cargar Profesionales al cambiar Especialidad
    especialidadSelect.addEventListener('change', async () => {
      const especialidadId = especialidadSelect.value;
      estado.especialidad = especialidadSelect.value;
      profesionalSelect.innerHTML = '<option>Cargando...</option>';
      profesionalSelect.disabled = true;
      
      // Resetear horarios también
      horaSelect.innerHTML = '<option value="" disabled selected>-- Seleccione fecha y profesional --</option>';
      horaSelect.disabled = true;

      try {
        const res = await fetch(`/profesionales/especialidad/${especialidadId}`);
        const data = await res.json();

        profesionalSelect.innerHTML = '<option value="" disabled selected>-- Seleccione Profesional --</option>';
        data.forEach(p => {
          const option = document.createElement('option');
          option.value = p.id; // 🔥 CLAVE
          option.textContent = p.nombre_completo;
          profesionalSelect.appendChild(option);
        });
        profesionalSelect.disabled = false;
      } catch (err) {
        console.error(err);
        profesionalSelect.innerHTML = '<option>Error al cargar</option>';
      }
    });

    // 3. Cargar Horarios al cambiar Profesional o Fecha
    async function cargarHorarios() {

      const profesionalId = profesionalSelect.value;
      const fecha = fechaInput.value;
      const tipoTurno = tipoTurnoSelect.value;

      estado.profesional = profesionalId;
      estado.fecha = fecha;
      estado.tipo = tipoTurno;

      console.log("ESTADO:", estado);

      if (!estado.profesional || !estado.fecha) {
        console.log("Faltan datos, no carga");
        return;
      }

      if (cargandoHorarios) return;
      cargandoHorarios = true;

      horaSelect.innerHTML = '<option>Cargando...</option>';
      horaSelect.disabled = true;

      try {

        const res = await fetch(
          `/turnos/horarios-disponibles/${estado.profesional}/${estado.fecha}?tipo=${estado.tipo}`,
          { cache: "no-store" }
        );

        const data = await res.json();

        console.log("DATA COMPLETA:", data);

        horaSelect.innerHTML = '';

        if (data.motivo) {

          const mensajes = {
            sin_agenda: 'El profesional no tiene agenda',
            ausente: 'El profesional está ausente ese día',
            no_trabaja: 'El profesional no trabaja ese día'
          };

          const option = document.createElement('option');
          option.textContent = mensajes[data.motivo] || 'No hay disponibilidad';
          option.disabled = true;
          option.selected = true;

          horaSelect.appendChild(option);
          horaSelect.disabled = true;
          return;
        }

        if (data.horarios && data.horarios.length > 0) {

          const defaultOption = document.createElement('option');
          defaultOption.textContent = '-- Seleccione Hora --';
          defaultOption.disabled = true;
          defaultOption.selected = true;

          horaSelect.appendChild(defaultOption);

          data.horarios.forEach(h => {

            const option = document.createElement('option');
            option.value = h.hora;

            if (h.estado === 'libre') {
              option.textContent = `🟢 ${h.hora} (Libre)`;
            }

            if (h.estado === 'ocupado') {
              option.textContent = `🔴 ${h.hora} (Completo)`;
              option.disabled = true;
            }

            if (h.estado === 'sobreturno') {
              option.textContent = `🔵 ${h.hora} (Sobreturno ${h.usados}/${h.max})`;
            }

            horaSelect.appendChild(option);
          });

          horaSelect.disabled = false;

        } else {
          const option = document.createElement('option');
          option.textContent = 'No hay horarios disponibles';
          option.disabled = true;
          option.selected = true;

          horaSelect.appendChild(option);
          horaSelect.disabled = true;
        }

      } catch (err) {
        console.error("ERROR FETCH:", err);
      } finally {
        cargandoHorarios = false;
      }
    }

        profesionalSelect.addEventListener('change', () => {
          estado.profesional = profesionalSelect.value;
          cargarHorarios();
        });
        //fechaInput.addEventListener('change', cargarHorarios);
        tipoTurnoSelect.addEventListener('change', () => {
          estado.tipo = tipoTurnoSelect.value;
          cargarHorarios();
        });

        document.addEventListener("DOMContentLoaded", () => {

          flatpickr("#fecha", {
            locale: "es",
            dateFormat: "Y-m-d",
            minDate: "today",
            onChange: function () {
              cargarHorarios(); // 🔥 clave: evento confiable
            }
          });

        });