doctype html
html
  head
    title
      block title
        | Agenda Consultorio

    // Bootstrap CSS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css", rel="stylesheet")

    // Custom CSS
    link(rel='stylesheet', href='/styles.css')

  body

    // NAVBAR SUPERIOR
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.shadow-sm
      .container
        a.navbar-brand(href='/')
          img.logo-navbar(src='/img/logo.png', alt='Logo')
          | Consultorio

        button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarNav')
          span.navbar-toggler-icon

        .collapse.navbar-collapse#navbarNav
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href='/') Inicio
            li.nav-item
              a.nav-link(href='/turnos') Turnos
            li.nav-item
              a.nav-link(href='/profesionales') Profesionales
            li.nav-item
              a.nav-link(href='/pacientes') Pacientes
            li.nav-item
              a.nav-link(href='/agendas') Agendas
            li.nav-item
              a.nav-link(href='/ausencias') Ausencias

    // CONTENIDO
    div.container.mt-4
      block content

    // Bootstrap JS Bundle
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")