extends layout

block title
  | Lista de Profesionales

block content
  h1 Lista de Profesionales

  form(method="GET" action="/profesionales" class="mb-3")
    .input-group
      input.form-control(
        type="text",
        name="buscar",
        placeholder="Buscar por nombre, apellido, DNI o matrícula...",
        value=filtro
      )
      button.btn.btn-primary(type="submit") Buscar

  .actions.mb-3
    a(href="/profesionales/nuevo" class="btn btn-primary") Agregar Nuevo Profesional
    a(href="/" class="btn btn-secondary ms-2") Volver a pagina principal

  if profesionales.length > 0
    div.table-responsive
      table.table.table-striped.table-bordered.table-hover
        thead
          tr
            th Matrícula
            th Nombre
            th Apellido
            th DNI
            th Teléfono
            th Email
            th Estado
            th Especialidades
            th Acciones
        tbody
          each profesional in profesionales
            tr
              td= profesional.matricula
              td= profesional.nombre
              td= profesional.apellido
              td= profesional.dni
              td= profesional.telefono || '-'
              td= profesional.email || '-'
              td
                span(class=`badge ${profesional.estado === 'activo' ? 'bg-success' : 'bg-danger'}`)= profesional.estado
              td
                if profesional.especialidades
                  ul.list-unstyled.mb-0
                    each especialidad in profesional.especialidades.split(',')
                      li= especialidad.trim()
                else
                  span.text-muted No tiene
              td
                a(href=`/profesionales/${profesional.id}/editar`, class='btn btn-warning btn-sm me-1') Editar
                form(action=`/profesionales/${profesional.id}/${profesional.estado === 'activo' ? 'inactivar' : 'activar'}`, method="POST", style="display:inline")
                  button(type="submit" class=`btn btn-sm ${profesional.estado === 'activo' ? 'btn-danger' : 'btn-success'}`) #{profesional.estado === 'activo' ? 'Inactivar' : 'Activar'}
  else
    p.alert.alert-info No hay profesionales registrados.

  .footer.mt-5.text-muted
    p © 2024 Agenda Médica. Isaias Felippo-Lucas fernandez.
