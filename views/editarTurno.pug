extends layout

block title
  | Editar Turno

block content
  .container.mt-4
    h1.mb-4 Editar Turno

    .card.shadow-sm
      .card-body

        .alert.alert-info.mb-4
          h5.mb-3 Contacto del Paciente
          p.mb-1
            strong Teléfono:
            |  #{turno.telefono || 'Sin teléfono'}

          p.mb-1
            strong Email:
            |  #{turno.email || 'Sin email'}

          p.mb-1
            strong Paciente:
            |  #{turno.paciente_nombre}

          a.btn.btn-warning.mt-2(
            href=`/pacientes/${turno.paciente_id}/editar`
          )
            | Editar Paciente
          

          

        form(action=`/turnos/${turno.id}/editar` method="POST")
          div.row.g-3

            div.col-md-6
              label.form-label(for="paciente_id") Paciente
              select.form-select(disabled)
                each paciente in pacientes
                  option(value=paciente.id selected=(paciente.id == turno.paciente_id))= paciente.nombre
              input(
                type="hidden"
                name="paciente_id"
                value=turno.paciente_id
              )

            div.col-md-6
              label.form-label Profesional
              select.form-select(
                name="profesional_id"
                id="profesional_id"
              )
                each profesional in profesionales
                  option(value=profesional.id selected=(profesional.id == turno.profesional_id))= profesional.nombre_completo

              

            div.col-md-6
              label.form-label Especialidad
              select.form-select(disabled)
                each especialidad in especialidades
                  option(value=especialidad.id selected=(especialidad.id == turno.especialidad_id))= especialidad.nombre

              input(type="hidden" name="especialidad_id" value=turno.especialidad_id)

            div.col-md-6
              label.form-label Sucursal
              input.form-control(type="text" disabled value=turno.sucursal_nombre)

            //- Fecha
            div.col-md-6
              label.form-label(for="fecha") Fecha

              input.form-control(
                type="text"
                name="fecha"
                id="fecha"
                value=turno.fecha_formateada
                autocomplete="off"
                required
              )

            //- Hora
            div.col-md-6
              label.form-label(for="hora") Horarios Disponibles

              small.text-muted.d-block.mb-1
                | 🟢 Libre | 🔵 Sobreturno | 🔴 Completo

              select.form-select(name="hora" id="hora" required)
                option(value=turno.hora selected)
                  = turno.hora

            div#mensajeTurno.mt-2

            div.col-md-6
              label.form-label Tipo de Turno
              select.form-select(name="tipo_turno")
                option(value="normal" selected=(turno.tipo_turno == 'normal')) Normal
                option(value="sobreturno" selected=(turno.tipo_turno == 'sobreturno')) Sobreturno

            div.col-md-6
              label.form-label Estado
              select.form-select(name="estado")
                option(value="confirmado" selected=(turno.estado == 'confirmado')) Confirmado
                option(value="cancelado" selected=(turno.estado == 'cancelado')) Cancelado
                option(value="pendiente" selected=(turno.estado == 'pendiente')) Pendiente
                option(value="reservado" selected=(turno.estado == 'reservado')) Reservado

          
            

              

          .mt-4
            button.btn.btn-warning(type="submit") Actualizar Turno
            a.btn.btn-secondary.ms-2(href="/turnos") Cancelar



  script.

              const profesionalSelect =
                document.getElementById('profesional_id');
              const fechaInput = document.getElementById('fecha');
              const horaSelect = document.getElementById('hora');

              function obtenerProfesionalActual() {
                return profesionalSelect.value;
              }

              profesionalSelect.addEventListener('change', async () => {

                if (calendario) {
                  calendario.destroy();
                }

                fechaInput.value = '';
                horaSelect.innerHTML =
                  '<option>Seleccione fecha</option>';

                cargarCalendario();

              });

              async function cargarHorarios() {

                const fecha = fechaInput.value;

                if (!fecha) return;

                horaSelect.innerHTML = '<option>Cargando...</option>';

                try {

                  const res = await fetch(
                    `/turnos/horarios-disponibles/${obtenerProfesionalActual()}/${fecha}`
                  );

                  const data = await res.json();

                  horaSelect.innerHTML = '';

                  if (data.horarios && data.horarios.length > 0) {

                    data.horarios.forEach(h => {

                      const option = document.createElement('option');

                      option.value = h.hora;

                      if (h.estado === 'libre') {
                        option.textContent = `🟢 ${h.hora} (Libre)`;
                      }

                      if (h.estado === 'ocupado') {
                        option.textContent = `🔴 ${h.hora} (Completo)`;
                        option.disabled = true;
                      }

                      if (h.estado === 'sobreturno') {
                        option.textContent =
                          `🔵 ${h.hora} (Sobreturno ${h.usados}/${h.max})`;
                      }

                      horaSelect.appendChild(option);

                    });

                  }

                } catch (err) {

                  console.error(err);

                }

              }

              let calendario = null;

              async function cargarCalendario() {

                try {

                  const res = await fetch(
                    `/turnos/disponibilidad-calendario/${obtenerProfesionalActual()}`
                  );

                  const data = await res.json();

                  calendario = flatpickr("#fecha", {

                    locale: "es",
                    dateFormat: "Y-m-d",
                    defaultDate: fechaInput.value,

                    enable: [
                      function(date) {

                        const diaJS = date.getDay();
                        const diaBD = diaJS === 0 ? 7 : diaJS;

                        const trabaja =
                          data.diasLaborales.includes(diaBD);

                        if (!trabaja) return false;

                        const fechaActual =
                          date.toISOString().split('T')[0];

                        const estaAusente = data.ausencias.some(a => {

                          return (
                            fechaActual >= a.fecha_inicio &&
                            fechaActual <= a.fecha_fin
                          );

                        });

                        return !estaAusente;

                      }
                    ],

                    onDayCreate: function(dObj, dStr, fp, dayElem) {

                      const fecha =
                        dayElem.dateObj.toISOString().split('T')[0];

                      const diaJS = dayElem.dateObj.getDay();
                      const diaBD = diaJS === 0 ? 7 : diaJS;

                      const trabaja =
                        data.diasLaborales.includes(diaBD);

                      const estaAusente = data.ausencias.some(a => {

                        return (
                          fecha >= a.fecha_inicio &&
                          fecha <= a.fecha_fin
                        );

                      });

                      if (!trabaja) {
                        dayElem.classList.add("no-disponible");
                        return;
                      }

                      if (estaAusente) {
                        dayElem.classList.add("ausente");
                        return;
                      }

                      dayElem.classList.add("disponible");

                    },

                    onChange: function() {

                      cargarHorarios();

                    }

                  });
                }
                catch(err) {

                  console.error(err);

                }
              }
              document.addEventListener("DOMContentLoaded", async () => {

                await cargarCalendario();

                cargarHorarios();

              });
                        