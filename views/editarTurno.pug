extends layout

block title
  | Editar Turno

block content
  .container.mt-4
    h1.mb-4 Editar Turno

    .card.shadow-sm
      .card-body

        .alert.alert-info.mb-4
          h5.mb-3 Contacto del Paciente
          p.mb-1
            strong Teléfono:
            |  #{turno.telefono || 'Sin teléfono'}

          p.mb-1
            strong Email:
            |  #{turno.email || 'Sin email'}

          p.mb-1
            strong Paciente:
            |  #{turno.paciente_nombre}

          a.btn.btn-warning.mt-2(
            href=`/pacientes/${turno.paciente_id}/editar`
          )
            | Editar Paciente
          

          

        form(action=`/turnos/${turno.id}/editar` method="POST")
          div.row.g-3

            div.col-md-6
              label.form-label(for="paciente_id") Paciente
              select.form-select(disabled)
                each paciente in pacientes
                  option(value=paciente.id selected=(paciente.id == turno.paciente_id))= paciente.nombre
              input(
                type="hidden"
                name="paciente_id"
                value=turno.paciente_id
              )

            div.col-md-6

              label.form-label Profesional

              .d-flex.align-items-center.gap-2

                select.form-select(
                  name="profesional_id"
                  id="profesional_id"
                )

                  each profesional in profesionales
                    option(
                      value=profesional.id
                      selected=(profesional.id == turno.profesional_id)
                    )= profesional.nombre_completo


                button.btn.btn-warning(
                  type="button"
                  id="btnRecargarProfesionales"
                  title="Mostrar todos los profesionales"
                )
                  i.bi.bi-arrow-clockwise.me-1
                  | Todos
                

            div.col-md-6
              label.form-label Especialidad

              select.form-select(
                name="especialidad_id"
                id="especialidad_id"
              )

                each especialidad in especialidades
                  option(
                    value=especialidad.id
                    selected=(especialidad.id == turno.especialidad_id)
                  )= especialidad.nombre

            div.col-md-6
              label.form-label Sucursal
              input.form-control(
              id="sucursal_nombre"
              disabled
              value=turno.sucursal_nombre
              )

            //- Fecha
            div.col-md-6
              label.form-label(for="fecha") Fecha

              input.form-control(
                type="text"
                name="fecha"
                id="fecha"
                value=turno.fecha_formateada
                autocomplete="off"
                required
              )

            //- Hora
            div.col-md-6
              label.form-label(for="hora") Horarios Disponibles

              small.text-muted.d-block.mb-1
                | 🟢 Libre | 🔵 Sobreturno | 🔴 Completo

              select.form-select(name="hora" id="hora" required)
                option(value=turno.hora selected)
                  = turno.hora

            div#mensajeTurno.mt-2

            div.col-md-6
              label.form-label Tipo de Turno
              select.form-select(name="tipo_turno")
                option(value="normal" selected=(turno.tipo_turno == 'normal')) Normal
                option(value="sobreturno" selected=(turno.tipo_turno == 'sobreturno')) Sobreturno

            div.col-md-6
              label.form-label Estado
              select.form-select(name="estado")
                option(value="confirmado" selected=(turno.estado == 'confirmado')) Confirmado
                option(value="cancelado" selected=(turno.estado == 'cancelado')) Cancelado
                option(value="pendiente" selected=(turno.estado == 'pendiente')) Pendiente
                option(value="reservado" selected=(turno.estado == 'reservado')) Reservado

          
            

              

          .mt-4
            button.btn.btn-warning(type="submit") Actualizar Turno

            a.btn.btn-secondary.ms-2(href="/turnos")
              | Cancelar

            button.btn.btn-info.ms-2(
              type="button"
              id="btnReset"
            )
              | Reiniciar

      


  script.

              const especialidadSelect =
                document.getElementById('especialidad_id');
              const sucursalInput =
                document.getElementById('sucursal_nombre');

              const profesionalSelect =
                document.getElementById('profesional_id');
              const fechaInput = document.getElementById('fecha');
              const horaSelect = document.getElementById('hora');
              const especialidadOriginal =
                "#{turno.especialidad_id}";

              const profesionalOriginal =
                "#{turno.profesional_id}";

              const fechaOriginal =
                "#{turno.fecha_formateada}";

              const horaOriginal =
                "#{turno.hora}";
              let actualizando = false;

              function obtenerProfesionalActual() {
                return profesionalSelect.value;
              }


              document.getElementById('btnRecargarProfesionales').addEventListener('click', async () => {
                console.log("CLICK");
                const res = await fetch('/profesionales/todos'); // Ruta que ya tenés
                console.log("RESPUESTA", res.status);
                const profesionales = await res.json();
                console.log(profesionales);
                console.log("CANTIDAD:", profesionales.length);
                console.log(JSON.stringify(profesionales));
                
                profesionalSelect.innerHTML = ''; // Limpiamos las opciones

                profesionales.forEach(p => {
                  console.log(p.nombre_completo);
                  const option = document.createElement('option');

                  option.value = p.id;
                  option.textContent = p.nombre_completo;

                  profesionalSelect.appendChild(option);
                });

                const seleccionado = profesionalOriginal;

                if (profesionales.some(p => p.id == seleccionado)) {
                  profesionalSelect.value = seleccionado;
                }

                profesionalSelect.dispatchEvent(
                  new Event('change')
                );     
              });

              profesionalSelect.addEventListener('change', async () => {
                console.log("CHANGE DISPARADO");
                if (actualizando) return;

                actualizando = true;

                const profesionalId = profesionalSelect.value;

                try {
                  
                  console.log(
                    'PROFESIONAL ACTUAL:',
                    obtenerProfesionalActual()
                  );
                  const res = await fetch(
                    `/profesionales/${profesionalId}/especialidades`
                  );

                  const especialidades = await res.json();

                  especialidadSelect.innerHTML = '';

                  
                  especialidades.forEach(e => {
                    const option = document.createElement('option');
                    option.value = e.id;
                    option.textContent = e.nombre;
                    especialidadSelect.appendChild(option);
                  });

                  // 👈 ACÁ SE TERMINA DE LLENAR EL SELECT

                  const especialidadId =
                    especialidadOriginal && especialidades.some(e => e.id == especialidadOriginal)
                      ? especialidadOriginal
                      : especialidades[0].id;

                  especialidadSelect.value = especialidadId;

                  

                  const resSuc = await fetch(
                    `/turnos/sucursal/${profesionalId}/${especialidadId}`
                  );

                  

                  const suc = await resSuc.json();

                  sucursalInput.value =
                  suc.sucursal_nombre || '';

                  if (calendario) {
                    calendario.destroy();
                  }

                  fechaInput.value = '';

                  horaSelect.innerHTML =
                    '<option>Seleccione fecha</option>';
  
                  console.log(
                    'PROFESIONAL PARA HORARIOS:',
                    obtenerProfesionalActual()
                  );
                  await cargarCalendario();

                } catch(err) {

                  console.error(err);

                }

                actualizando = false;

              });
              

              especialidadSelect.addEventListener('change', async () => {

                if (actualizando) return;

                actualizando = true;

                const especialidadId = especialidadSelect.value;

                const res = await fetch(
                  `/profesionales/especialidad/${especialidadId}`
                );

                const profesionales = await res.json();

                profesionalSelect.innerHTML = '';

                profesionales.forEach(p => {

                  const option = document.createElement('option');

                  option.value = p.id;
                  option.textContent = p.nombre_completo;

                  profesionalSelect.appendChild(option);

                });

                

                if (profesionales.length > 0) {

                  if (profesionales.some(
                    p => p.id == profesionalOriginal
                  )) {

                    profesionalSelect.value =
                      profesionalOriginal;

                  } else {

                    profesionalSelect.value =
                      profesionales[0].id;

                  }
                  const resSuc = await fetch(

                  `/turnos/sucursal/${
                  profesionalSelect.value
                  }/${
                  especialidadId
                  }`

                  );

                  const suc = await resSuc.json();

                  sucursalInput.value =
                  suc.sucursal_nombre || '';


                  

                }


                if (calendario) {
                  calendario.destroy();
                }

                await cargarCalendario();
                  actualizando = false;

              });

              async function cargarHorarios() {

                const fecha = fechaInput.value;
                const profesionalId = obtenerProfesionalActual();

                if (!profesionalId) {
                  console.warn(
                    'No hay profesional seleccionado'
                  );
                  return;
                }

                if (!fecha) return;
                horaSelect.innerHTML = '<option>Cargando...</option>';

                try {

                  const especialidadId =
                    especialidadSelect.value;

                  const res = await fetch(

                  `/turnos/horarios-disponibles/${
                  obtenerProfesionalActual()
                  }/${
                  fecha
                  }?especialidadId=${
                  especialidadId
                  }&turnoId=#{turno.id}`

                  );

                  const data = await res.json();

                  horaSelect.innerHTML = '';

                  if (data.horarios && data.horarios.length > 0) {

                    data.horarios.forEach(h => {

                      const option = document.createElement('option');

                      option.value = h.hora;

                      if (h.estado === 'libre') {
                        option.textContent = `🟢 ${h.hora} (Libre)`;
                      }

                      if (h.estado === 'ocupado') {
                        option.textContent = `🔴 ${h.hora} (Completo)`;
                        option.disabled = true;
                      }

                      if (h.estado === 'sobreturno') {
                        option.textContent =
                          `🔵 ${h.hora} (Sobreturno ${h.usados}/${h.max})`;
                      }

                      horaSelect.appendChild(option);

                    });

                  }

                } catch (err) {

                  console.error(err);

                }

              }

              let calendario = null;

              async function cargarCalendario() {

                const profesionalId =
                  obtenerProfesionalActual();

                if (!profesionalId) {
                  console.warn(
                    'No hay profesional seleccionado'
                  );
                  return;
                }

                try {

                  const res = await fetch(
                    `/turnos/disponibilidad-calendario/${profesionalId}`
                  );

                  const data = await res.json();

                  calendario = flatpickr("#fecha", {

                    locale: "es",
                    dateFormat: "Y-m-d",
                    defaultDate: fechaInput.value,

                    enable: [
                      function(date) {

                        const diaJS = date.getDay();
                        const diaBD = diaJS === 0 ? 7 : diaJS;

                        const trabaja =
                          data.diasLaborales.includes(diaBD);

                        if (!trabaja) return false;

                        const fechaActual =
                          date.toISOString().split('T')[0];

                        const estaAusente = data.ausencias.some(a => {

                          return (
                            fechaActual >= a.fecha_inicio &&
                            fechaActual <= a.fecha_fin
                          );

                        });

                        return !estaAusente;

                      }
                    ],

                    onDayCreate: function(dObj, dStr, fp, dayElem) {

                      const fecha =
                        dayElem.dateObj.toISOString().split('T')[0];

                      const diaJS = dayElem.dateObj.getDay();
                      const diaBD = diaJS === 0 ? 7 : diaJS;

                      const trabaja =
                        data.diasLaborales.includes(diaBD);

                      const estaAusente = data.ausencias.some(a => {

                        return (
                          fecha >= a.fecha_inicio &&
                          fecha <= a.fecha_fin
                        );

                      });

                      if (!trabaja) {
                        dayElem.classList.add("no-disponible");
                        return;
                      }

                      if (estaAusente) {
                        dayElem.classList.add("ausente");
                        return;
                      }

                      dayElem.classList.add("disponible");

                    },

                    onChange: function() {

                      cargarHorarios();

                    }

                  });
                }
                catch(err) {

                  console.error(err);

                }
              }
              document.addEventListener("DOMContentLoaded", async () => {

                await cargarCalendario();

                cargarHorarios();

              });

              document.getElementById('btnReset')
                .addEventListener('click', async () => {

                  actualizando = true;

                  profesionalSelect.value =
                    profesionalOriginal;

                  especialidadSelect.value =
                    especialidadOriginal;

                  fechaInput.value =
                    fechaOriginal;

                  if (calendario) {
                    calendario.destroy();
                  }

                  await cargarCalendario();

                  await cargarHorarios();

                  horaSelect.value =
                    horaOriginal;

                  actualizando = false;

                });
                        