extends layout

block title
  | Editar Ausencia

block content
  h1 Editar Ausencia

  form(action=`/ausencias/${ausencia.id}/editar` method="POST")
    div.mb-3
      label.form-label(for="profesional_id") Profesional
      select.form-select(name="agenda_id" id="agenda_id" required)
        each agenda in agendas
          option(
            value=agenda.id
            selected=(agenda.id == ausencia.agenda_id)
          )= agenda.nombre
    div.row.g-3.mb-3
      div.col-md-6
        label.form-label(for="fecha_inicio") Fecha Inicio
        //- Asumiendo que el controlador envía la fecha en formato YYYY-MM-DD
        input.form-control(type="date" name="fecha_inicio" id="fecha_inicio" value=ausencia.fecha_inicio required)
      
      div.col-md-6
        label.form-label(for="fecha_fin") Fecha Fin
        //- Asumiendo que el controlador envía la fecha en formato YYYY-MM-DD
        input.form-control(type="date" name="fecha_fin" id="fecha_fin" value=ausencia.fecha_fin required)

    div.mb-3
      label.form-label(for="motivo") Motivo
      input.form-control(type="text" name="motivo" id="motivo" value=ausencia.motivo)

    div.mt-4
      button.btn.btn-warning(type="submit") Actualizar Ausencia
      a.btn.btn-secondary.ms-2(href="/ausencias") Cancelar

  .card.mt-4.historial-ausencias

      .card-header
          h5.mb-0 Historial de ausencias


      .card-body

        .timeline-scroll

          .timeline-content

            .timeline-header

              each mes in ['Jun 2026','Jul 2026','Ago 2026','Sep 2026','Oct 2026']

                .mes

                  .mes-titulo= mes

                  .dias

                    each _, i in Array.from({length:31})

                      span= String(i+1).padStart(2,'0')


            each a in ausencias

              - const esActual = a.id == ausencia.id
              - const PX_DIA = 14

              - const left = a.offset * PX_DIA
              - const width = a.dias * PX_DIA


              .fila-ausencia

                .info

                  strong= a.motivo

                  br

                  small
                    = a.inicioTexto
                    |  al
                    = a.finTexto


                .barra-contenedor

                  .barra(
                    class=esActual ? 'actual' : 'anterior'
                    style=`left:${left}px;width:${width}px`
                  )

                  if esActual

                    .badge.bg-primary.editando

                      | Editando