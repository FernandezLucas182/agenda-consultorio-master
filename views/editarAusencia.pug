extends layout

block title
  | Editar Ausencia

block content
  h1 Editar Ausencia

  form(action=`/ausencias/${ausencia.id}/editar` method="POST")
    div.mb-3
      label.form-label(for="profesional_id") Profesional
      select.form-select(name="profesional_id" id="profesional_id" required)
        each prof in profesionales
          option(value=prof.id selected=(prof.id == ausencia.profesional_id))= prof.nombre_completo

    div.row.g-3.mb-3
      div.col-md-6
        label.form-label(for="fecha_inicio") Fecha Inicio
        //- Asumiendo que el controlador envía la fecha en formato YYYY-MM-DD
        input.form-control(type="date" name="fecha_inicio" id="fecha_inicio" value=ausencia.fecha_inicio required)
      
      div.col-md-6
        label.form-label(for="fecha_fin") Fecha Fin
        //- Asumiendo que el controlador envía la fecha en formato YYYY-MM-DD
        input.form-control(type="date" name="fecha_fin" id="fecha_fin" value=ausencia.fecha_fin required)

    div.mb-3
      label.form-label(for="motivo") Motivo
      input.form-control(type="text" name="motivo" id="motivo" value=ausencia.motivo)

    div.mt-4
      button.btn.btn-warning(type="submit") Actualizar Ausencia
      a.btn.btn-secondary.ms-2(href="/ausencias") Cancelar