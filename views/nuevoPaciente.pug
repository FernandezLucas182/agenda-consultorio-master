doctype html
html
  head
    title Nuevo Paciente
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel='stylesheet', href='/styles.css')
  body
    div.container.mt-5
      h1.mb-4 Crear Nuevo Paciente

      form(action='/pacientes', method='POST')

        div.mb-3
          label.form-label Nombre y Apellido:
          input.form-control(type='text', name='nombre', required)

        div.mb-3
          label.form-label DNI:
          input.form-control(type='text', name='dni', required)

        div.mb-3
          label.form-label Obra Social:
          input.form-control(type='text', name='obra_social')

        div.mb-3
          label.form-label Contacto:
          input.form-control(type='text', name='contacto')

        button.btn.btn-primary(type='submit') Guardar
        a.btn.btn-secondary.ms-2(href='/pacientes') Volver
