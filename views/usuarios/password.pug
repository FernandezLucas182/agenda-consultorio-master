extends ../layout

block content

    h2.mb-4 Resetear contraseña

    form(method='POST')

        .mb-3
            label.form-label Nueva contraseña

            input.form-control(
                type='password'
                name='password'
                required
            )

        button.btn.btn-success(type='submit')
            i.bi.bi-key
            |  Guardar contraseña

        a.btn.btn-secondary.ms-2(href='/usuarios')
            Volver