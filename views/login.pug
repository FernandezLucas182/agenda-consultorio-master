doctype html
html
  head
    title Iniciar sesión

    link(
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    )

    link(rel="stylesheet", href="/styles.css")

  body.login-page

    .login-overlay

      .login-card

        img.login-logo(src="/img/logo.png")

        h2 Sistema de Gestión
        h5 Consultorio Médico

        if error
          .alert.alert-danger.mt-3= error

        form(action="/login" method="POST")

          .mb-3
            input.form-control(
              type="text"
              name="username"
              placeholder="Usuario"
              required
            )

          .mb-3
            input.form-control(
              type="password"
              name="password"
              placeholder="Contraseña"
              required
            )

          button#loginButton.btn.btn-success.w-100(type="submit")
            | Iniciar sesión

    script.
      const btn = document.getElementById("loginButton");

      btn.addEventListener("click", function () {

          const rect = btn.getBoundingClientRect();

          for(let i=0;i<12;i++){

              const star = document.createElement("span");

              star.className="login-star";

              star.innerHTML="✦";

              document.body.appendChild(star);

              const angle=Math.random()*Math.PI*2;
              const distance=40+Math.random()*55;

              const x=Math.cos(angle)*distance;
              const y=Math.sin(angle)*distance;

              star.style.left=(rect.left+rect.width/2)+"px";
              star.style.top=(rect.top+rect.height/2)+"px";

              star.style.setProperty("--x",x+"px");
              star.style.setProperty("--y",y+"px");

              setTimeout(()=>star.remove(),700);

          }

      });