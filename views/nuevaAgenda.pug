extends layout

block title
  | Nueva Agenda

block content
  h1 Crear Agenda de Atención

  form(action="/agendas/nueva" method="POST")
    // DATOS GENERALES
    h3.mt-4.mb-3 Datos Generales
    div.row.g-3
      div.col-md-6
        label.form-label(for="profesionalSelect") Profesional
        select.form-select(name="profesional_id" id="profesionalSelect" required)
          option(value="" disabled selected) -- Selecciona profesional --
          each profesional in profesionales
            option(value=profesional.id)
              | #{profesional.nombre} #{profesional.apellido}

      div.col-md-6
        label.form-label(for="especialidadSelect") Especialidad
        select.form-select(name="especialidad_id" id="especialidadSelect" required)
          option(value="" disabled selected) -- Selecciona especialidad --
          each esp in especialidades
            option(value=esp.id)= esp.nombre
      
      div.col-md-6
        label.form-label(for="sucursal_id") Sucursal
        select.form-select(name="sucursal_id" id="sucursalSelect" required)
          option(value="" disabled selected) -- Selecciona sucursal --

      div#alertaAgendaExistente.alert.alert-danger.mt-2.d-none

      div.col-md-6
        label.form-label(for="duracion_turno") Duración del turno (minutos)
        select.form-select(name="duracion_turno" id="duracion_turno" required)
          option(value="" disabled selected) -- Seleccionar duración --
          option(value="10") 10 minutos
          option(value="20") 20 minutos
          option(value="30") 30 minutos
          option(value="40") 40 minutos
          option(value="50") 50 minutos
          option(value="60") 60 minutos

    // DISPONIBILIDAD SEMANAL
    h3.mt-5.mb-3 Disponibilidad semanal

    - const dias = [{id:1,nombre:"Lunes"},{id:2,nombre:"Martes"},{id:3,nombre:"Miércoles"},{id:4,nombre:"Jueves"},{id:5,nombre:"Viernes"},{id:6,nombre:"Sábado"},{id:7,nombre:"Domingo"}]

    each dia in dias
      div.card.mb-3
        div.card-header
          div.form-check
            input.form-check-input.check-dia(type="checkbox" data-dia=dia.id id=`check-${dia.id}`)
            label.form-check-label(for=`check-${dia.id}`)
              strong #{dia.nombre}

        div.card-body(id=`bloques-${dia.id}`)
          //- Los bloques se agregarán aquí

        div.card-footer
          button.btn.btn-outline-primary.btn-sm(type="button" onclick=`agregarBloque(${dia.id})`) + Agregar bloque horario

    div.mt-4
      button#btnGuardar.btn.btn-success.btn-lg(type="submit")
        | Guardar Agenda Completa
      a.btn.btn-secondary.btn-lg.ms-2(href="/agendas") Volver

  // SCRIPT
  script.
    document.addEventListener('DOMContentLoaded', () => {

      const profesionalSelect = document.getElementById('profesionalSelect');
      const especialidadSelect = document.getElementById('especialidadSelect');
      const sucursalSelect = document.getElementById('sucursalSelect');
      const btnGuardar = document.getElementById('btnGuardar');
      const alertaAgendaExistente = document.getElementById('alertaAgendaExistente');
      

      const horariosDisponibles = [
        "09:00","09:30","10:00","10:30","11:00","11:30",
        "12:00","12:30","13:00",
        "16:00","16:30","17:00","17:30","18:00","18:30",
        "19:00","19:30","20:00","20:30","21:00"
      ];

      let bloqueIndex = 0;

      sucursalSelect.addEventListener('change', () => {
        verificarDisponibilidad();
      });
      
    //=========================
    //Verificar disponibilidad
    //=========================
      async function verificarDisponibilidad() {
        const profesionalId = profesionalSelect.value;
        const especialidadId = especialidadSelect.value;

        if (!profesionalId || !especialidadId) return;

        const res = await fetch(
          `/agendas/disponibilidad/${profesionalId}/${especialidadId}/${sucursalId}`
        );

        const data = await res.json();

        if (!data.disponible) {
          btnGuardar.disabled = true;
          alertaAgendaExistente.classList.remove('d-none');
          alertaAgendaExistente.innerHTML =
            "Ya existe una agenda activa para este profesional, especialidad y sucursal.";
        } else {
          btnGuardar.disabled = false;
          alertaAgendaExistente.classList.add('d-none');
        }
      }

      // =========================
      // SUCURSALES (SOLO 1 VEZ)
      // =========================
      async function cargarSucursales() {
        try {
          const res = await fetch('/sucursales');
          const sucursales = await res.json();

          sucursalSelect.innerHTML =
            '<option disabled selected>Selecciona sucursal</option>';

          sucursales.forEach(s => {
            const option = document.createElement('option');
            option.value = s.id;
            option.textContent = s.nombre;
            sucursalSelect.appendChild(option);
          });

        } catch (err) {
          console.error("Error sucursales:", err);
        }
      }

      cargarSucursales();

      // =========================
      // DISPONIBILIDAD
      // =========================
      
      // =========================
      // PROFESIONAL CHANGE
      // =========================
      profesionalSelect.addEventListener('change', async () => {
        const profesionalId = profesionalSelect.value;

        especialidadSelect.innerHTML =
          '<option disabled selected>Cargando...</option>';

        try {
          const res = await fetch(`/profesionales/${profesionalId}/especialidades`);
          const especialidades = await res.json();

          especialidadSelect.innerHTML =
            '<option disabled selected>Selecciona especialidad</option>';

          especialidades.forEach(e => {
            const option = document.createElement('option');
            option.value = e.id;
            option.textContent = e.nombre;
            especialidadSelect.appendChild(option);
          });

        } catch (err) {
          console.error(err);
        }
        verificarDisponibilidad();
        
      });

      // =========================
      // ESPECIALIDAD CHANGE
      // =========================
      especialidadSelect.addEventListener('change', () => {
        verificarDisponibilidad();
      });

      // =========================
      // BLOQUES HORARIOS
      // =========================
      window.agregarBloque = function(dia) {

        const contenedor = document.getElementById('bloques-' + dia);

        const options = horariosDisponibles
          .map(h => `<option value="${h}">${h}</option>`)
          .join('');

        const div = document.createElement('div');
        div.className = 'row g-2 align-items-center mb-2';

        div.innerHTML = `
          <input type="hidden" name="horarios[${bloqueIndex}][dia]" value="${dia}">
          <div class="col-auto"><label>Desde:</label></div>
          <div class="col-auto">
            <select name="horarios[${bloqueIndex}][desde]" required>
              <option value="">--</option>${options}
            </select>
          </div>
          <div class="col-auto"><label>Hasta:</label></div>
          <div class="col-auto">
            <select name="horarios[${bloqueIndex}][hasta]" required>
              <option value="">--</option>${options}
            </select>
          </div>
          <div class="col-auto">
            <button type="button" onclick="this.parentElement.parentElement.remove()">X</button>
          </div>
        `;

        contenedor.appendChild(div);
        bloqueIndex++;
      };

    });