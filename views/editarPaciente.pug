extends layout

block title
  | Editar Paciente

block content
  h1 Editar Paciente

  form(action=`/pacientes/${paciente.id}/editar` method="POST")
    div.mb-3
      label.form-label(for="nombre") Nombre Completo
      input.form-control(type="text" id="nombre" name="nombre" value=paciente.nombre required)

    div.mb-3
      label.form-label(for="dni") DNI
      input.form-control(type="text" id="dni" name="dni" value=paciente.dni required)

    div.mb-3
      label.form-label(for="obra_social") Obra Social
      input.form-control(type="text" id="obra_social" name="obra_social" value=paciente.obra_social)

    div.mb-3
      label.form-label(for="contacto") Contacto (Teléfono/Email)
      input.form-control(type="text" id="contacto" name="contacto" value=paciente.contacto)

    div.mt-4
      button.btn.btn-success(type="submit") Guardar Cambios
      a.btn.btn-secondary.ms-2(href="/pacientes") Cancelar